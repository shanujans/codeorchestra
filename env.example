# Band Protocol -- get this from the dashboard's "Connect Remote Agent" flow
# (must be an agent key, prefixed band_a_ -- a band_u_ user key will not work)
BAND_API_KEY=
BAND_REST_URL=https://app.band.ai/api/v1

# OpenRouter -- used for Coder/Reviewer/Tester/Docs (openrouter/free auto-router)
OPENROUTER_API_KEY=

# AI/ML API -- used for Planner (o3-mini)
AIML_API_KEY=

# GitHub -- optional, only needed for private repos / to avoid rate limits
GITHUB_TOKEN=

# Set to "true" to sample the final QAOA circuit on real IBM Quantum hardware
# (requires `pip install qiskit-ibm-runtime` and a saved IBM account).
# Falls back to local simulation automatically if unset or if the connection fails.
USE_IBM_HARDWARE=false
